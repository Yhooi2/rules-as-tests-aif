#!/usr/bin/env bash
# Pre-push hook: heavier checks (target: ≤30 seconds).
# Author-side enforcement for rules-as-tests-aif repo.
# Installs via: make install-hooks
#
# Probes (Decision matrix MUST + SHOULD rows, self-application.md §3):
#   - actionlint:             on .github/workflows/*.yml
#   - zizmor:                 on .github/workflows/
#   - Self-test pipeline:     bash tests/audit/audit-ai-docs.test.sh
#   - Manifest render drift:  npx tsx scripts/render-rules.ts --check

set -euo pipefail

# ── 1. actionlint ────────────────────────────────────────────────────────────
if ! command -v actionlint &>/dev/null; then
  echo "❌ actionlint not found in PATH."
  echo "   Install: brew install actionlint   (macOS)"
  echo "         or: go install github.com/rhysd/actionlint/cmd/actionlint@latest"
  exit 1
fi

actionlint .github/workflows/*.yml

# ── 2. zizmor ────────────────────────────────────────────────────────────────
if ! command -v zizmor &>/dev/null; then
  echo "❌ zizmor not found in PATH."
  echo "   Install: pip install zizmor"
  exit 1
fi

zizmor --format plain .github/workflows/

# ── 3. Self-test pipeline ─────────────────────────────────────────────────────
if [ -x tests/audit/audit-ai-docs.test.sh ]; then
  bash tests/audit/audit-ai-docs.test.sh
else
  echo "❌ tests/audit/audit-ai-docs.test.sh missing or not executable"
  exit 1
fi

# ── 4. Manifest render drift ──────────────────────────────────────────────────
# --check flag verified to exist in scripts/render-rules.ts (line 77)
if command -v npx &>/dev/null; then
  npx tsx scripts/render-rules.ts --check
else
  echo "❌ npx not found. Install Node.js to enable manifest render drift check."
  exit 1
fi

exit 0
